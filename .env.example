# HERE deploy environment — copy to .env (gitignored) and edit as needed.
# rpi/scripts/deploy.sh reads this when run from the repo root.

# How to reach the Pi over SSH. PI_HOST can be a hostname (mDNS) or IP.
# The matching ~/.ssh/config alias takes precedence for key + user; this
# file is just for the script.
PI_HOST=here.local
PI_USER=here

# Field-debug WiFi AP — a persistent SSID the Pi broadcasts alongside
# its home-WiFi client connection. Pi 4's CYW43455 supports concurrent
# AP+STA on a single radio, so this works at the same time as the home
# network. In the field with no home WiFi around, your phone can join
# this AP and hit http://here.local:8000/ or SSH directly.
#
# Leave AP_SSID empty to skip AP setup entirely.
AP_SSID=here-debug
AP_PSK=change-me
